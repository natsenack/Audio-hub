[Desktop Entry]
Type=Application
Name=Linux Audio Manager
Comment=Manage audio devices and volume routing
Exec=linux-audio-manager
Icon=io.github.linux-audio-manager
Terminal=false
Categories=Audio;System;GNOME;
Keywords=audio;volume;sound;pipewire;routing;
DBusActivatable=false

# App ID for Flathub (optional but recommended)
X-Flatpak=io.github.linux-audio-manager

# Localization
Name[fr]=Gestionnaire Audio Linux
Comment[fr]=Gérez les périphériques audio et le routage du volume

# GNOME-specific
StartupNotify=true
X-GNOME-Bugzilla-Bugzilla=GNOME
X-GNOME-Bugzilla-Product=linux-audio-manager
X-GNOME-Bugzilla-Component=General
X-GNOME-UsesNotifications=true

